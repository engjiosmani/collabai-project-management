# Copy to backend/.env (not committed)
# DEBUG=True
# SECRET_KEY=dev-only-change-in-production

# PostgreSQL (optional overrides)
# DB_NAME=collabai_db
# DB_USER=postgres
# DB_PASSWORD=admin123

# Redis Stack (required for #17 caching + Celery + optional RAG vectors). Use Redis Stack, not plain Redis.
# Without REDIS_URL, Django falls back to in-memory cache (tests only — run: python manage.py check_redis)
REDIS_URL=redis://127.0.0.1:6379/0
# CACHE_DEFAULT_TIMEOUT=300
# METRICS_CACHE_TIMEOUT=60

# Groq LLM (https://console.groq.com) — never commit the real key
GROQ_API_KEY=gsk_your_key_from_console.groq.com
GROQ_MODEL=llama-3.1-8b-instant

# RAG embeddings (downloads ~80MB on first use)
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_AUTO_INDEX=true
# Set true if Redis Stack is not installed (semantic search in process memory)
# RAG_FORCE_MEMORY_STORE=true

# Celery: worker + beat for Team Pulse schedules
# celery -A config worker -l info
# celery -A config beat -l info
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=true
TEAM_PULSE_STANDUP_HOUR=9

# GitHub (per-workspace PAT is saved via API — do not commit real tokens)
# Create a fine-grained PAT with repo read access for commit history in standups.

