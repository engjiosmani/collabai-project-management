# ==============================================================================
# CollabAI - Environment Configuration Template
# Copy this file to `backend/.env` for local development.
# Do NOT commit the actual `.env` file to version control.
# ==============================================================================

# --- Django Core Settings ---
DEBUG=True
# Generate a unique local key; do not reuse this sample outside development.
SECRET_KEY=AkZsDCJdu9MfMoQ2RoLKSdwnd4ra4t2AdeYpfqdqxmCmc8ALF648IliWfI1wVNb2
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# --- CORS & CSRF Settings ---
# In development, CORS_ALLOW_ALL_ORIGINS=True allows all origins. In production, set to False and specify CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL_ORIGINS=True
# Comma-separated list of origins allowed to make cross-site HTTP requests:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Comma-separated list of trusted origins for CSRF protection:
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# --- Simple JWT Settings ---
# Access token lifespan in minutes (recommended: 15-60)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# Refresh token lifespan in days (recommended: 7-14)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
# Whether to rotate refresh tokens upon reuse (highly recommended)
JWT_ROTATE_REFRESH_TOKENS=True
# Whether to blacklist old refresh tokens after rotation (requires simplejwt blacklist app)
JWT_BLACKLIST_AFTER_ROTATION=True

# --- Database Settings (PostgreSQL) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=collabai_db
# DB_USER=postgres
# DB_PASSWORD=12345678

# --- Redis Stack Configuration ---
# Required for caching, Celery task broker, and vector index. Use Redis Stack, not plain Redis.
# Without REDIS_URL, Django falls back to in-memory cache (tests only — run: python manage.py check_redis)
REDIS_URL=redis://127.0.0.1:6379/0
# CACHE_DEFAULT_TIMEOUT=300
# METRICS_CACHE_TIMEOUT=60

# --- Groq LLM Configuration ---
# Generate your API key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_from_console.groq.com
GROQ_MODEL=llama-3.1-8b-instant

# --- RAG Embeddings & Search ---
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_AUTO_INDEX=true
# Set True if Redis Stack/RediSearch is not installed to fall back to in-process memory store
# RAG_FORCE_MEMORY_STORE=true

# --- Throttling / Rate Limiting (Brute-force protection) ---
# Rates defined as: requests/period (e.g. 5/minute, 100/day)
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=1000/hour
# Tighter per-endpoint brute-force limits for critical authentication routes
THROTTLE_AUTH_LOGIN_RATE=5/minute
THROTTLE_AUTH_REGISTER_RATE=3/minute
THROTTLE_AUTH_REFRESH_RATE=10/minute

# --- Production Security Hardening (SSL/HSTS & Cookies) ---
# In production, set SECURE_SSL_REDIRECT to True, set a long HSTS duration (e.g., 31536000),
# and set the secure cookies to True (assuming running under HTTPS).
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_PROXY_SSL_HEADER_ENABLED=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# --- Celery and Task Scheduling ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CRITICAL: Set to False in production! If True, tasks run synchronously and block the request thread.
CELERY_TASK_ALWAYS_EAGER=true
TEAM_PULSE_STANDUP_HOUR=9
