# Copy to backend/.env (not committed)
# DEBUG=True
# SECRET_KEY=dev-only-change-in-production

# PostgreSQL (optional overrides)
# DB_NAME=collabai_db
# DB_USER=postgres
# DB_PASSWORD=admin123

# Redis Stack (vector search + cache). Use Redis Stack, not plain Redis.
REDIS_URL=redis://127.0.0.1:6379/0

# Groq LLM (https://console.groq.com) — never commit the real key
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# RAG embeddings (downloads ~80MB on first use)
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_AUTO_INDEX=true
# Set true if Redis Stack is not installed (semantic search in process memory)
# RAG_FORCE_MEMORY_STORE=true

# Celery: run worker with: celery -A config worker -l info
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=true
